{# Stats row — expects: items (array), accent_color (string, optional) #}
<div class="sts rv">
  {%- for item in items %}
  <div class="st">
    <div class="sv-n" {% if accent_color %}style="color:{{ accent_color }}"{% endif %} data-count="{{ item.value }}" data-suffix="{{ item.suffix }}">0</div>
    <div class="sv-l">{{ item.label }}</div>
  </div>
  {%- endfor %}
</div>
